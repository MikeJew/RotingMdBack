## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Original source: https://github.com/github/gitignore/blob/main/VisualStudio.gitignore

# User-specific files
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates

# User-specific files (MonoDevelop/Xamarin Studio)
*.userprefs

# Mono auto generated files
mono_crash.*

# Build results
[Dd]ebug/
[Dd]ebugPublic/
[Rr]elease/
x64/
x86/
[Aa]rm/
[Aa]rm64/
bld/
[Bb]in/
[Ob]j/
[L]og/
[L]ogs/

# Visual Studio 2015/2017/2019/2022 cache/options directory
.vs/
# Uncomment if multiple varieties of Visual Studio are used but a common parent directory is shared
#*vs*/

# MSTest test Results
[Tt]est[Rr]esults/
[Bb]uild[Ll]og.*

# NUnit
*.VisualState.xml
TestResult.xml
nunit-agent*

# Output of MSBuild
*.suo
*.user
*.userosscache
*.sln.docstates

# ReSharper is a clean library
_ReSharper*/
*.[Re]Sharper.user

# Rider
.idea/

# VS Code
.vscode/

# OS-specific
.DS_Store
Thumbs.db
